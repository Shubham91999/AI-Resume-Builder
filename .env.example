# ============================================================
# AI Resume Tailor — Environment Variables
# Copy this file to .env and fill in your API keys
# ============================================================

# --- LLM Provider Keys (at least ONE required) ---
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=

# --- Google Drive Integration (optional, Phase 10) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- App Settings ---
# Backend
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# Optional: restrict download endpoints to token-authenticated requests.
# Leave blank for single-user local use. Set to a strong random string for
# shared/production deployments: openssl rand -hex 32
APP_SECRET_TOKEN=

# Set to false in production to enable strict CORS, security headers, and HTTPS warnings.
DEBUG=true

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# Logging
LOG_LEVEL=INFO
